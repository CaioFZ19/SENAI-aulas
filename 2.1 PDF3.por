programa {
  funcao inicio() {
    
    //Variáveis
inteiro numero = 42, chute

    //Atribuição de valores
escreva ("Tente adivinhar o número! (Dica, está entre 1 e 100) \n")
leia (chute)

    //Comando em loop: enquanto
enquanto (chute != numero) {
  escreva ("Errado! Tente novamente: ")
  leia (chute)
} escreva ("Parabéns, você acertou!")


escreva ("\n")
escreva ("\n")
  }
}
