programa {
  funcao inicio() {
    
    //Variáveis
inteiro numero, multiplicador

    //Atribuição de valores
escreva ("Digite um número: ")
leia (numero)

    //Comando em loop: para
para (multiplicador = 1 ; multiplicador <=10 ; multiplicador ++)
escreva (numero, " x ", multiplicador, " = ", numero * multiplicador, "\n")


escreva ("\n")
escreva ("\n")
  }
}
