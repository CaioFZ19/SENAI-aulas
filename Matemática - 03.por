programa {
  funcao inicio() {
    
real n1, n2, n3, n4

escreva ("Qual a sua primeira nota? ")
leia (n1)
escreva ("\n")

escreva ("Qual a sua segunda nota? ")
leia (n2)
escreva ("\n")

escreva ("Qual a sua terceira nota? ")
leia (n3)
escreva ("\n")

escreva ("Qual a sua quarta nota? ")
leia (n4)
escreva ("\n")

escreva ("Sua média foi ")
escreva ((n1 + n2 + n3 + n4) / 4)


escreva ("\n")
escreva ("\n")
  }
}
