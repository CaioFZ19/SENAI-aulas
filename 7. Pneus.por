programa {
  funcao inicio() {
    
    //Variáveis
inteiro carros
inteiro pneus

    //atribuição de valores
escreva ("Quantos carros serão produzidos? ")
leia (carros)
escreva ("\n")

pneus = (carros * 5)

escreva ("Será necessário encomendar ")
escreva (pneus)
escreva (" pneus, incluindo 1 estepe por carro.")


escreva ("\n")
escreva ("\n")
  }
}
