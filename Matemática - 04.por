programa {
  funcao inicio() {
    
real celsius, fah

escreva ("Insira a temperatura em celcius para ser convertida para fahrenheit:", "\n")
leia (celsius)
escreva ("\n")

fah = ((celsius * 1.8) + 32)

escreva ("Convertendo ", celsius, "°C para fahrenheit, temos: ", fah, "°F")


escreva ("\n")
escreva ("\n")
  }
}
