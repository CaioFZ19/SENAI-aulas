programa {
  funcao inicio() {

inteiro nascimento, anoA = 2026, idade

escreva ("Em que ano você nasceu? ")
leia (nascimento)
escreva ("\n")

idade = (anoA - nascimento)

se (idade >= 18) {
  escreva ("Você já é maior de idade, com ", idade, " anos.")
} senao{
  escreva ("Você ainda é menor de idade, com ", idade, " anos")
}


escreva ("\n")
escreva ("\n")
  }
}
