programa {
  funcao inicio() {
    cadeia nome
    inteiro idade
escreva ("qual o seu nome? ")
leia (nome)
escreva ("qual a sua idade? ") 
leia (idade)

  escreva ("Seja bem vindo, ") 
  escreva (nome)
  escreva ("\n")
  escreva ("Você tem ")
  escreva (idade)
  escreva (" anos")
  escreva ("\n")
  escreva ("\n")
  escreva ("\n")
  escreva ("\n")

  }
}
