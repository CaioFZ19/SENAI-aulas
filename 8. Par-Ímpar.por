programa {
  funcao inicio() {
    
    //Variáveis
inteiro numero
inteiro resto

    //Atribuição de valores
escreva ("digite um número inteiro")
escreva ("\n")
leia (numero)
escreva ("\n")

    //Contas
resto = numero % 2 

escreva ("Se resto = 0 -> par \n")
escreva ("Se resto = 1 -> ímpar \n")
escreva ("\n")
escreva ("Resto = ")
escreva (resto)

    escreva ("\n")
    escreva ("\n")
  }
}
