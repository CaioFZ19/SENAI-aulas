programa {
  funcao inicio() {
    
    //Variáveis
real numero

    //Atribuição de valores
escreva ("Digite um número: ")
leia (numero)
escreva ("\n")

    //IF/ELSE
se (numero > 0) {
  escreva ("Número positivo")
} senao se (numero < 0) {
  escreva ("Número negativo")
} senao {
  escreva ("Número igual a zero")
}


escreva ("\n")
escreva ("\n")
  }
}
